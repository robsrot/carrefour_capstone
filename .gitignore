# DATA — never commit
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Common data formats (safety net anywhere in repo)
*.csv
*.parquet
*.feather
*.xlsx
*.json
*.pkl
*.zip
*.tar.gz
*.gz

# MODELS — too large for git
models/*
!models/.gitkeep

# OUTPUTS
outputs/*
!outputs/.gitkeep

# PYTHON
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# JUPYTER
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db